# Rust build artifacts
/target
**/*.rs.bk
Cargo.lock.orig

# Reference source trees (terminator + alacritty) are cloned locally for study
# but MUST NOT be committed into rt's history — they have their own licenses
# and would bloat the repo. See docs/REFERENCES.md for how to re-fetch them.
/reference/

# Packaging output
/dist/
*.deb
*.rpm
*.pkg.tar.zst

# Editor / OS noise
*.swp
.DS_Store

# Stray top-level dump files (e.g. an accidental `ls -R > 1`) that git add -A
# would otherwise sweep in. See the 201MB file-1 incident.
/1
/2
/.cargo

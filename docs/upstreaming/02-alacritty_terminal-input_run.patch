+    /// `input_run` must produce grid and cursor state identical to feeding the
+    /// same characters one at a time through `input`.
+    fn assert_input_run_matches(cols: usize, lines: usize, insert: bool, wrap: bool, text: &str) {
+        let size = TermSize::new(cols, lines);
+        let mut per_char = Term::new(Config::default(), &size, VoidListener);
+        let mut batched = Term::new(Config::default(), &size, VoidListener);
+        for term in [&mut per_char, &mut batched] {
+            term.mode.set(TermMode::INSERT, insert);
+            term.mode.set(TermMode::LINE_WRAP, wrap);
+        }
+
+        for c in text.chars() {
+            per_char.input(c);
+        }
+        batched.input_run(text);
+
+        // Compare cell-by-cell through the grid index (which handles the ring
+        // buffer's rotation) rather than `Grid`'s `PartialEq`, whose `Storage`
+        // comparison asserts a non-rotated buffer and cannot compare scrollback.
+        let ctx = format!("cols={cols}, lines={lines}, insert={insert}, wrap={wrap}, text={text:?}");
+        for line in (per_char.grid.topmost_line().0..=per_char.grid.bottommost_line().0).map(Line) {
+            for col in (0..cols).map(Column) {
+                assert_eq!(
+                    per_char.grid[line][col], batched.grid[line][col],
+                    "cell mismatch at {line:?} {col:?} ({ctx})"
+                );
+            }
+        }
+        assert_eq!(
+            per_char.grid.cursor.point, batched.grid.cursor.point,
+            "cursor point mismatch ({ctx})"
+        );
+        assert_eq!(
+            per_char.grid.cursor.input_needs_wrap, batched.grid.cursor.input_needs_wrap,
+            "input_needs_wrap mismatch ({ctx})"
+        );
+    }
+
+    #[test]
+    fn input_run_matches_input() {
+        // Pure ASCII long enough to wrap and scroll several times.
+        let long_ascii: String = (0..500).map(|i| (b'!' + (i % 90) as u8) as char).collect();
+        // ASCII interleaved with wide CJK, exercising the wide fallback + boundaries.
+        let mixed = "abc你好def世界ghijklmnop你q";
+        // Content sized to land exactly on a row boundary for the small width.
+        let exact = "0123456789";
+
+        for &(cols, lines) in &[(10usize, 5usize), (7, 3), (20, 8), (2, 4)] {
+            for text in [long_ascii.as_str(), mixed, exact, "x", ""] {
+                assert_input_run_matches(cols, lines, false, true, text);
+                assert_input_run_matches(cols, lines, false, false, text);
+                assert_input_run_matches(cols, lines, true, true, text);
+            }
+        }
+    }
